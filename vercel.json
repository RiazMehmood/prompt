{
  "version": 2,
  "builds": [
    {
      "src": "backend/src/main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/src/main.py"
    }
  ],
  "env": {
    "SUPABASE_URL": "@supabase-url",
    "SUPABASE_KEY": "@supabase-key",
    "JWT_SECRET_KEY": "@jwt-secret",
    "GEMINI_API_KEY": "@gemini-api-key",
    "GOOGLE_CLIENT_ID": "@google-client-id",
    "REDIS_URL": "@redis-url"
  }
}
