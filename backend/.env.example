# ============================================================
# Database — Supabase
# ============================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ============================================================
# AI / LLM — Gemini (comma-separated for key rotation)
# ============================================================
GEMINI_API_KEYS=key1,key2,key3
GEMINI_MODEL=gemini-1.5-flash

# ============================================================
# Auth
# ============================================================
JWT_SECRET=your_jwt_secret_min_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Twilio (SMS OTP for Pakistan phone numbers)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================================
# Vector Store — ChromaDB
# Change ONLY this one path to move ChromaDB to a different drive/directory.
# Current: external drive to avoid root partition space issues.
# Fallback for local dev with space: ./data/chromadb
# ============================================================
CHROMADB_PATH=/media/riaz/New Volume/zero-cost setup/chroma_data
CHROMADB_EMBEDDING_MODEL=intfloat/multilingual-e5-base

# ============================================================
# OCR (MVP — Tesseract + EasyOCR)
# ============================================================
TESSERACT_CMD=/usr/bin/tesseract
TESSERACT_LANG_PATH=/usr/share/tesseract-ocr/4.00/tessdata
OCR_CONFIDENCE_THRESHOLD=0.70
OCR_FALLBACK_ENABLED=true

# ============================================================
# Voice / Speech (Phase 2 — Pilot)
# Leave blank for MVP
# ============================================================
OPENAI_API_KEY=sk-your_openai_api_key
VOICE_AUDIO_TEMP_DIR=./data/voice_temp
VOICE_AUDIO_MAX_SIZE_MB=25
VOICE_AUDIO_DELETE_SECONDS=30

# ============================================================
# Text-to-Speech (Phase 3 — Full Scale)
# Leave blank for MVP and Pilot
# ============================================================
GOOGLE_CLOUD_TTS_KEY=./path/to/gcp-service-account.json
GOOGLE_CLOUD_TTS_VOICE_URDU=ur-IN-Wavenet-A
GOOGLE_CLOUD_TTS_VOICE_ENGLISH=en-US-Standard-C

# ============================================================
# Application settings
# ============================================================
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006

# RAG settings
RAG_MIN_CONFIDENCE=0.75
SEMANTIC_CACHE_THRESHOLD=0.92
MAX_UPLOAD_SIZE_MB=10

# Subscription
SHOW_PAID_TIERS=false
