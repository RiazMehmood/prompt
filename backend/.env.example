# Environment variables for backend (Checkpoint 1 - Free MVP)
# Copy this file to .env and fill in your actual values

# Supabase Configuration (Free Tier)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Gemini AI Configuration (Free Tier - 15 RPM)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback/google

# Upstash Redis Configuration (Free Tier - 10k commands/day)
REDIS_URL=redis://your-upstash-url:6379
REDIS_TOKEN=your-upstash-token

# Application
ENVIRONMENT=development
DEBUG=true
